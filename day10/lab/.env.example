# Day 10 Lab - copy thanh .env va dien neu can
#   cp .env.example .env

# ChromaDB (khuyen nghi tach collection khoi Day 09)
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION=day10_kb

# Embedding
EMBEDDING_PROVIDER=sentence_transformer
EMBEDDING_MODEL=all-MiniLM-L6-v2
# Neu dung Jina API:
# EMBEDDING_PROVIDER=jina
# EMBEDDING_MODEL=jina-embeddings-v2-base-en
# JINA_API_KEY=

# Freshness SLA (gio) - dung trong monitoring/freshness_check.py
FRESHNESS_SLA_HOURS=24

# Tuy chon: OpenAI chi can neu nhom mo rong eval bang LLM-judge
# OPENAI_API_KEY=
